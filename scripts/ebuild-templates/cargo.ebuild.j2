# NOTE: This template is NOT used for cargo packages.
# Cargo ebuilds are generated by pycargoebuild (reads Cargo.lock for the full CRATES list).
# See track-releases.py -> generate_cargo_ebuild().
#
# This file is kept as a reference for the expected ebuild shape.

# Copyright {{ year }} Gentoo Authors
# Distributed under the terms of the GNU General Public License v2

EAPI=8

CRATES="
	# populated by pycargoebuild
"

inherit cargo

DESCRIPTION="{{ description }}"
HOMEPAGE="{{ homepage }}"
SRC_URI="
	https://github.com/{{ github }}/archive/refs/tags/{{ tag_prefix }}${PV}.tar.gz -> ${P}.tar.gz
	${CARGO_CRATE_URIS}
"

LICENSE="{{ license }}"
SLOT="{{ slot }}"
KEYWORDS="~amd64"

src_unpack() {
	cargo_src_unpack
}

src_compile() {
	cargo_src_compile
}

src_install() {
	cargo_src_install
	einstalldocs
}
