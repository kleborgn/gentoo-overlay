EAPI=8
{% if eclasses %}
inherit {{ eclasses | join(" ") }}
{% endif %}

DESCRIPTION="{{ description }}"
HOMEPAGE="{{ homepage }}"
SRC_URI="
{% for a in arch_assets %}	{{ a.arch }}? (
		https://github.com/{{ github }}/releases/download/{{ tag_prefix }}${PV}/{{ a.filename_ebuild }} ->
		${P}-{{ a.arch }}.{{ a.ext }} )
{% endfor %}"
{% if not arch_assets %}
SRC_URI="https://github.com/{{ github }}/releases/download/{{ tag_prefix }}${PV}/${P}.tar.gz"
{% endif %}

LICENSE="{{ license }}"
SLOT="{{ slot }}"
KEYWORDS="{{ keywords }}"
{% if restrict %}
RESTRICT="{{ restrict }}"
{% endif %}

{% if rdepend %}
RDEPEND="
{% for dep in rdepend %}	{{ dep }}
{% endfor %}"
{% endif %}

S="${WORKDIR}"
{% if qa_prebuilt %}
QA_PREBUILT="{{ qa_prebuilt }}"
{% endif %}

